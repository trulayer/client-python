#!/usr/bin/env bash
# pre-push: runs on every `git push`. Blocks the push on any failure.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

fail() { echo "❌ $*" >&2; exit 1; }
step() { echo "▶ $*"; }

step "client-python: lint (ruff)"
uv run ruff check . || fail "lint failed"

step "client-python: type check (mypy)"
uv run mypy . || fail "type check failed"

step "client-python: tests"
uv run pytest || fail "tests failed"

step "client-python: build"
uv build || fail "build failed"

echo "✅ pre-push checks passed"
